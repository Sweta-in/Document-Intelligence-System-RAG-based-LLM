# ── LLM Configuration ──
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o-mini

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking ──
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ──
TOP_K=5
SIMILARITY_THRESHOLD=0.35

# ── FAISS Persistence ──
FAISS_INDEX_PATH=./data/faiss_index

# ── Upload Directory ──
UPLOAD_DIR=./data/uploads

# ── Logging ──
LOG_LEVEL=INFO
